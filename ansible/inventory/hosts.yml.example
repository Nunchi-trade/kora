# Kora devnet Ansible inventory
#
# Copy this file to hosts.yml and fill in your values:
#   cp hosts.yml.example hosts.yml
#
# Requirements:
#   - Target must be Arch Linux (playbooks use pacman)
#   - SSH access via key-based authentication
#   - hosts.yml is gitignored to protect server IPs
#
# Note: The provision playbook creates a 'kora' service user for docker
# operations. Root SSH is only needed for the initial provision run.
# After provisioning, deploy/stop/reset playbooks use become_user: kora.
all:
  children:
    devnet:
      hosts:
        hetzner-devnet:
          ansible_host: YOUR_SERVER_IP
          ansible_user: root
          ansible_python_interpreter: /usr/bin/python3
